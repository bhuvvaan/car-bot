# Telegram bot token from @BotFather
TELEGRAM_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Your Telegram chat ID (get from https://api.telegram.org/bot<TOKEN>/getUpdates)
MY_CHAT_ID=123456789

# Anthropic API key from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Hyundai/Kia Bluelink credentials
# Region: 1=Europe, 2=Canada, 3=USA, 4=Korea
BLUELINK_REGION=3

# Brand: 1=Kia, 2=Hyundai, 3=Genesis
BLUELINK_BRAND=2

BLUELINK_USERNAME=your_bluelink_email@example.com
BLUELINK_PASSWORD=your_bluelink_password
BLUELINK_PIN=1234
